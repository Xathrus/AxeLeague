[Unit]
Description=Abilene Axe League web app
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/axeleague
Environment=AXE_DB=/opt/axeleague/data/axeleague.db
ExecStart=/opt/axeleague/venv/bin/gunicorn --workers 1 --threads 8 --bind 0.0.0.0:80 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
